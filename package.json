{
  "type": "module",
  "name": "idl",
  "version": "0.3.15",
  "description": "----",
  "author": {
    "name": "liyanyu",
    "email": "liuerdan001@gmail.com",
    "url": "https://www.codebuddy.com"
  },
  "scripts": {
    "dev": "vite --mode development",
    "build": "tsc -b && vite build --mode live",
    "desktop:dev": "node ./electron/dev.mjs",
    "desktop:build": "npm run build",
    "preview": "vite preview --mode live",
    "format": "prettier ./src --write",
    "lint": "eslint .",
    "clean": "rm -rf dist release idl.app idl-*-mac.zip* *.dmg latest-mac.yml builder-*.yml builder-*.json",
    "desktop:start": "ELECTRON_RENDERER_URL=http://localhost:3000 electron .",
    "check-ts": "tsc --noEmit",
    "test:vitest": "vitest --mode test",
    "test": "npm run test:vitest",
    "dist":"./build.sh"
  },
  "main": "electron/main.mjs",
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.17.0",
    "radix-ui": "^1.4.3",
    "react": "18.3.1",
    "react-day-picker": "^10.0.1",
    "react-dom": "18.3.1",
    "react-markdown": "9.0.1",
    "react-router-dom": "6.26.1",
    "tailwind-merge": "^3.6.0",
    "zustand": "4.5.5"
  },
  "devDependencies": {
    "@eslint/js": "9.9.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/electron": "^1.6.12",
    "@types/node": "22.4.1",
    "@types/react": "18.3.3",
    "@types/react-color": "3.0.12",
    "@types/react-dom": "18.3.0",
    "@types/react-router-dom": "5.3.3",
    "@typescript-eslint/eslint-plugin": "8.1.0",
    "@vitejs/plugin-react-swc": "3.7.0",
    "dotenv": "16.4.5",
    "electron": "43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "9.9.0",
    "eslint-plugin-react-hooks": "5.1.0-rc-fb9a90fa48-20240614",
    "eslint-plugin-react-refresh": "0.4.9",
    "fs": "0.0.1-security",
    "globals": "15.9.0",
    "jsdom": "24.1.1",
    "prettier": "3.3.3",
    "react-color": "2.19.3",
    "shadcn": "^4.10.0",
    "tailwindcss": "^4.3.0",
    "ts-node": "10.9.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.6.2",
    "vite": "^5.4.20",
    "vite-plugin-checker": "^0.11.0",
    "vite-tsconfig-paths": "5.0.1",
    "vitest": "2.0.5"
  },
  "build": {
    "appId": "com.idl.ocr",
    "productName": "mac-OCR",
    "electronDist": "node_modules/electron/dist",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "release",
      "buildResources": "public/img"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!electron/dev.mjs",
      "public/**/*",
      "package.json",
      "!node_modules",
      "!**/node_modules/**/*",
      "!dist/**/*.map"
    ],
    "asar": true,
    "asarUnpack": [
      "electron/ocr.swift",
      "electron/screen-ocr-engine.bin"
    ],
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "compression": "maximum",
    "electronLanguages": ["en", "zh-CN"],
    "mac": {
      "target": [
        {
          "target": "dir",
          "arch": ["arm64"]
        }
      ],
      "category": "public.app-category.productivity",
      "darkModeSupport": true,
      "identity": null,
      "icon": "public/img/icon.png"
    }
  }
}
